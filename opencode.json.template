{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "instructions": ["AGENTS.md"],
  "agent": {
    "intake": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "description": "Intake / Requirement Expander. Turns a minimal prompt into workspace/requirements.md. Documents assumptions instead of asking questions. Stops for human review before Planner runs.",
      "prompt": "{file:./opencode-agents/intake.md}",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "description": "Planner. Reads approved workspace/requirements.md, produces workspace/plan.md + workspace/architecture.md + acceptance tests in workspace/tests/. Does NOT write implementation code.",
      "prompt": "{file:./opencode-agents/planner.md}",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      }
    },
    "implementer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "description": "Implementer. Implements one task from workspace/plan.md. Runs tests/linter in an inner loop until green. Raises PLAN DEFECT if the plan is unrealizable. Does NOT modify workspace/ artifacts.",
      "prompt": "{file:./opencode-agents/implementer.md}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "description": "Reviewer. Independently verifies one completed task: runs tests, judges what tests don't catch. Outputs APPROVE or REJECT (CODE DEFECT / PLAN DEFECT). Does NOT fix code.",
      "prompt": "{file:./opencode-agents/reviewer.md}",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      }
    },
    "pipeline": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "description": "Main entry point. Orchestrates the full pipeline: intake → [human gate] → planner → implementer ↔ reviewer per task. Pauses at human gates and escalations. Call with the feature description as the message.",
      "prompt": "{file:./opencode-agents/pipeline.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny"
      }
    }
  }
}
